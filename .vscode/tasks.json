{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Problem Test",
      "type": "shell",
      "command": "make",
      "args": ["build/${input:problemPath}/test"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ],
  "inputs": [
    {
      "id": "problemPath",
      "type": "promptString",
      "description": "Problem path (e.g. sliding_window/replacement)",
      "default": "sliding_window/replacement"
    }
  ]
}
